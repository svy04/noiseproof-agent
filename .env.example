POSTGRES_DB=noiseproof
POSTGRES_USER=noiseproof
POSTGRES_PASSWORD=noiseproof
POSTGRES_PORT=5432
DATABASE_URL=postgresql://noiseproof:noiseproof@localhost:5432/noiseproof
API_PORT=8000
MAX_RAW_UPLOAD_BYTES=1000000

# Raw upload scanner execution defaults to unavailable so the service never
# claims a clean verdict without an explicit scanner runtime.
NOISEPROOF_SCANNER=unavailable
RAW_FILE_SCANNER_TIMEOUT_SECONDS=30
CLAMD_HOST=clamav
CLAMD_PORT=3310

# Planned later phases; not used by Day 1.
OPENAI_API_KEY=
EMBEDDING_MODEL=
NOISEPROOF_ENABLE_OPENAI_PROVIDER=false
OPENAI_PROVIDER_TIMEOUT_SECONDS=10
